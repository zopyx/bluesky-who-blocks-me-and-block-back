    "list.detail.delete_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently deletes the list and all its members. This cannot be undone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht die Liste und alle Mitglieder dauerhaft. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci supprime définitivement la liste et tous ses membres. Action irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina permanentemente la lista e tutti i suoi membri. Azione irreversibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これによりリストと全メンバーが完全に削除されます。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除列表及其所有成员。此操作无法撤消。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente la lista y todos sus miembros."
          }
        },
        "pt": {
