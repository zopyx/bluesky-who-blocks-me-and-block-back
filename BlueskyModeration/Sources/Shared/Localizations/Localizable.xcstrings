    "list.snapshot.help_1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snapshots capture the full membership of this list at a point in time."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnappschüsse erfassen die vollständige Mitgliedschaft der Liste zu einem Zeitpunkt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les instantanés capturent l'ensemble des membres de la liste à un moment donné."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le istantanee catturano l'intera appartenenza della lista in un punto nel tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スナップショットは、ある時点のリストの完全なメンバーシップを取得します。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "快照捕捉列表在某个时间点的完整成员信息。"
          }
        },
        "es": {
