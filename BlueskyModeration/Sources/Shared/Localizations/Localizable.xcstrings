    },
    "%@ of %@%@" : {
      "comment" : "A progress bar with a label showing the current progress of a long-running action. The first argument is the number of completed steps. The second argument is the total number of steps. The third argument is an optional suffix that provides additional context about the action.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ of %2$@%3$@"
          }
        }
      }
    },
    "%@ succeeded, %@ failed" : {
      "comment" : "A message that shows the number of actions that succeeded and failed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ succeeded, %2$@ failed"
          }
        }
      }
    },
    "%@/%@" : {
      "comment" : "A label displaying the number of pending tasks that succeeded and failed. The first argument is the number of tasks that succeeded. The second argument is the total number of tasks (sum of succeeded and failed).",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
