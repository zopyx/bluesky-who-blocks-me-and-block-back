    "info.keychain.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Account secrets never leave your device. All API calls go directly to your Bluesky PDS."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Account-Geheimnisse verlassen nie Ihr Gerät. Alle API-Aufrufe gehen direkt an Ihr Bluesky-PDS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les secrets du compte ne quittent jamais votre appareil. Tous les appels API vont directement à votre PDS Bluesky."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I segreti dell'account non lasciano mai il tuo dispositivo. Tutte le chiamate API vanno direttamente al tuo PDS Bluesky."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントの秘密はデバイスから出ることはありません。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "账户机密数据永远不会离开您的设备。所有 API 调用直接发送到您的 Bluesky PDS。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Account secrets never leave your device. Todos API calls go directly to your Bluesky PDS."
          }
        },
        "pt": {
