    "onboarding.moderation.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Browse lists, search for actors, import or export members, and compare lists."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Listen durchsuchen, nach Accounts suchen, Mitglieder importieren/exportieren und Listen vergleichen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parcourir les listes, rechercher des comptes, importer/exporter des membres et comparer des listes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sfoglia liste, cerca account, importa/esporta membri e confronta liste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リストの閲覧、アカウント検索、メンバーのインポート/エクスポート、リストの比較。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览列表、搜索账户、导入/导出成员、比较列表。"
