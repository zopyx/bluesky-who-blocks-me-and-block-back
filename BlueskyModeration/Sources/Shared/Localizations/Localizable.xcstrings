{
  "sourceLanguage" : "en",
  "strings" : {
    "%@" : {
      "comment" : "A badge displaying the number of members in a list. The argument is the number of members in the list.",
      "isCommentAutoGenerated" : true
    },
    "%@ (%@)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ (%2$@)"
          }
        }
      }
    },
    "%@ completed" : {
      "comment" : "A label that indicates that a pending action has completed.",
      "isCommentAutoGenerated" : true
    },
    "%@ of %@%@" : {
      "comment" : "A progress bar and a label that shows the progress of an action. The first argument is the number of items that have been processed. The second argument is the total number of items. The third argument is an optional handle that can be used to cancel the action.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ of %2$@%3$@"
          }
        }
      }
    },
    "%@ succeeded, %@ failed" : {
      "comment" : "A message that shows the number of actions that succeeded and failed.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ succeeded, %2$@ failed"
          }
        }
      }
    },
    "%@/%@" : {
      "comment" : "A label displaying the number of pending tasks that succeeded and failed. The first argument is the number of tasks that succeeded. The second argument is the total number of tasks (sum of succeeded and failed).",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@/%2$@"
          }
        }
      }
    },
    "%@/%@ resolved" : {
      "comment" : "A label showing the number of resolved and unresolved results. The argument is the number of resolved results, the second argument is the total number of results.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@/%2$@ resolved"
          }
        }
      }
    },
    "%@x" : {
      "comment" : "A count of how many times a given user has been moderated.",
      "isCommentAutoGenerated" : true
    },
    "+ %@ more" : {
      "comment" : "A label that shows the number of additional mutual followers beyond the first 20.",
      "isCommentAutoGenerated" : true
    },
