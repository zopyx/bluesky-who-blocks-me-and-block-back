    "info.clearsky.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blockier- und Blockier-durch-Daten werden von ClearSky bereitgestellt. ClearSky indexiert Blockeinträge aus dem Bluesky-Firehose und stellt sie über eine öffentliche API bereit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données de blocage sont fournies par ClearSky. ClearSky indexe les enregistrements de blocage du firehose Bluesky via une API publique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati di blocco sono forniti da ClearSky. ClearSky indicizza i record di blocco dal firehose Bluesky e li rende disponibili tramite API pubblica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブロックデータはClearSkyによって提供されています。"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "屏蔽和被屏蔽数据由 ClearSky 提供。ClearSky 从 Bluesky 数据流索引屏蔽记录，并通过公共 API 提供。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. Sin authentication is required."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. Não authentication is required."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (한국어)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (RU)"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Blocking and blocked-by data is provided by ClearSky. ClearSky indexes block records from the Bluesky firehose and makes them available via a public API. No authentication is required. (AR)"
          }
        },
        "nl": {
